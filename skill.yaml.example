# Optional ClawHub / OpenClaw bundle manifest (some publish flows use skill.yaml).
# Copy to skill.yaml and adjust before publish if your tooling requires it.
#
# Reference: https://docs.openclaw.ai/tools/clawhub

name: atlas-avatar
version: 1.0.5
author: northmodellabs
description: >
  Atlas GPU avatars — realtime LiveKit sessions and offline lip-sync video
  via the Atlas API.

permissions:
  - network

config:
  # At runtime, map this to env ATLAS_API_KEY if your publish flow does not inject it automatically.
  atlas_api_key:
    type: string
    required: true
    description: Atlas API key (ak_...)

entryPoint:
  type: natural
  prompt: |
    Load instructions from SKILL.md in this bundle. Prefer python3 core/atlas_cli.py
    from the monorepo root (or scripts/run_atlas_cli.py with ATLAS_AGENT_REPO) with
    ATLAS_API_KEY; fall back to curl where Python is unavailable.
