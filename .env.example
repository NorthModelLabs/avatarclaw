# Copy to .env and fill in (never commit .env)
ATLAS_API_KEY=ak_your_key_here

# Optional — default production API
ATLAS_API_BASE=https://api.atlasv1.com

# Optional — monorepo root if you use skills/atlas-avatar/scripts/run_atlas_cli.py without core/ nearby
# ATLAS_AGENT_REPO=/absolute/path/to/avatarclaw

# Optional — atlas-bridge-slack / atlas-bridge-discord (webhooks are secrets)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL_ID=C0123456789          # for MP4 upload: channel ID (Profile → Copy channel ID)
# BOT_OAUTH_TOKEN=xoxb-...              # Bot User OAuth Token; needs files:write + chat:write (see slack-app-manifest)
# SLACK_MESSAGE_STYLE=minimal           # default: caption + link only. Use full for debug bullets (session_id, room, …)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_MESSAGE_STYLE=minimal           # default: caption + plain links. Use full for debug bullets + rich embeds
# --- Optional: interactive bot (not webhook) — /ask, @mention, reply-to-bot → LLM + MP4; /generate → verbatim ---
# pip install -r skills/atlas-bridge-discord/requirements.txt   # includes discord.py
# DISCORD_BOT_TOKEN=...                    # Application → Bot → Token
# DISCORD_MESSAGE_CONTENT_INTENT=1         # optional: @mention text (must match Portal → Message Content ON)
# DISCORD_GUILD_MEMBERS_INTENT=1           # optional: large servers / @mention quirks (Portal → Server Members ON)
# DISCORD_AVATAR_DEBUG=1                   # optional: log reply-to-bot / reference fetch (no message text)
# DISCORD_GUILD_ID=1234567890123456789     # optional: slash commands only in this server = instant sync (Server → right-click → Copy Server ID)
# /ask + reply-to-bot: HELICONE_API_KEY (Helicone AI Gateway — default) or ANTHROPIC_API_KEY (direct Anthropic).
# HELICONE_ANTHROPIC_PROXY=1 + both keys = legacy anthropic.helicone.ai proxy (BYOK + observability).
# LLM_MODEL defaults: claude-sonnet-4 (gateway) or claude-sonnet-4-20250514 (native Anthropic).
# ./scripts/bridges/run-discord-avatar-bot.sh
# Smoke tests (no Atlas): ./scripts/bridges/test-slack-webhook.sh  ./scripts/bridges/test-discord-webhook.sh
# Slack link / Discord MP4: ./scripts/bridges/test-slack-video-link.sh   ./scripts/bridges/test-discord-with-mp4.sh
# Atlas offline → Discord attach: ./scripts/bridges/atlas-offline-to-discord.sh (needs ATLAS_API_KEY + DISCORD_WEBHOOK_URL)

# --- Narrated avatar → Discord (scripts/bridges/atlas-narrated-avatar-to-discord.sh) ---
# pip install -r scripts/requirements-narrator.txt   # boto3 for S3
# ffmpeg on PATH — avatar_discord_narrator.py converts ElevenLabs MP3 → WAV before Atlas (avoids static if server mis-reads MP3)
# HELICONE_API_KEY=sk-helicone-...   # /ask default: ai-gateway.helicone.ai (Helicone credits)
# LLM_MODEL=claude-sonnet-4
# ANTHROPIC_API_KEY=sk-ant-...       # omit if using gateway only; else direct api.anthropic.com
# HELICONE_ANTHROPIC_PROXY=1         # optional: with BOTH keys, use anthropic.helicone.ai instead of gateway
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # optional; any voice id from ElevenLabs
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_ENDPOINT_URL_S3=https://...     # S3-compatible endpoint (e.g. Tigris / R2 / AWS)
# AWS_REGION=auto                       # omit or set; "auto" is skipped for boto3 region_name
# Optional — claude-code-avatar/scripts/make-test-assets.sh: copy a face instead of S3/URL
# ATLAS_LOCAL_FACE_PATH=/path/to/face.jpg
# ATLAS_SKIP_S3_FACE=1                 # force URL fixture even when AWS_* is set
# Optional — atlas-offline-to-slack.sh / atlas-offline-to-discord.sh: spoken line via ElevenLabs (needs ELEVENLABS_API_KEY + ffmpeg)
# ATLAS_OFFLINE_SPEAK_TEXT=Hello from Atlas
# AVATARHUB_S3_BUCKET=avatarhub
# AVATARHUB_S3_PREFIX=                    # optional prefix when listing face images

# Optional — for OpenClaw + custom LLM (documented in INTEGRATION.md)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://your-openclaw-gateway/api/v1/openai
